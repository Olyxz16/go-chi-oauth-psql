{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "go@1.24.9",
    "air@1.61.7",
    "postgresql_16@latest",
    "atlas@latest",
    "sqlc@latest"
  ],
  "shell": {
    "init_hook": [],
    "scripts": {
      "up": "process-compose up",
      "down": "process-compose down",
      "watch:api": "air -c air.api.toml",
      "migrate": "atlas migrate apply --dir 'file://internal/db/migrations' --url 'postgres://postgres:postgres@localhost:5432/app?sslmode=disable'"
    }
  }
}

